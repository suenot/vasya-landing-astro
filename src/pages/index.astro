---
import BaseLayout from '../layouts/BaseLayout.astro';
import translations from '../data/translations.json';
import { Image } from 'astro:assets';
import '../styles/page.css';

// Import images
import featureVoiceAi from '../assets/feature_voice_ai.png';
import featureFocus from '../assets/feature_focus_v2.png';
import featureMulti from '../assets/feature_multi_account.png';
import featurePrivacy from '../assets/feature_privacy_first.png';
import featureNative from '../assets/feature_native_speed.png';
import featureSummaries from '../assets/feature_summaries.png';

import downloadMac from '../assets/download_mac.png';
import downloadWindows from '../assets/download_windows.png';
import downloadLinux from '../assets/download_linux.png';
import downloadAndroid from '../assets/download_android.png';
import downloadIos from '../assets/download_ios.png';
import downloadWeb from '../assets/download_web.png';
import logoSvg from '../assets/vasyapp.svg';

const t = translations.en; // Default for SSR
const APP_VERSION = 'v0.1.2';
const RELEASE = 'https://github.com/suenot/vasya/releases/download/v0.1.2';

const downloads = [
  {
    id: 'mac',
    image: downloadMac,
    labelKey: 'downloadForMac',
    variants: [
      { labelKey: 'macSilicon', ext: ' (.dmg)', href: `${RELEASE}/Vasyapp_0.1.2_aarch64.dmg` },
      { labelKey: 'macIntel', ext: ' (.dmg)', href: `${RELEASE}/Vasyapp_0.1.2_x64.dmg` },
    ],
  },
  {
    id: 'windows',
    image: downloadWindows,
    labelKey: 'downloadForWindows',
    variants: [
      { labelKey: 'windowsExe', ext: ' (.exe)', href: `${RELEASE}/Vasyapp_0.1.2_x64-setup.exe` },
    ],
  },
  {
    id: 'linux',
    image: downloadLinux,
    labelKey: 'downloadForLinux',
    variants: [
      { labelKey: 'linuxDeb', ext: ' (Ubuntu/Debian)', href: `${RELEASE}/Vasyapp_0.1.2_amd64.deb` },
      { labelKey: 'linuxRpm', ext: ' (Fedora/RHEL)', href: `${RELEASE}/Vasyapp-0.1.2-1.x86_64.rpm` },
    ],
  },
  {
    id: 'android',
    image: downloadAndroid,
    labelKey: 'downloadForAndroid',
    variants: [
      { labelKey: 'androidApk', ext: '', href: `${RELEASE}/app-universal-release-unsigned.apk` },
    ],
  },
  {
    id: 'ios',
    image: downloadIos,
    labelKey: 'downloadForIos',
    comingSoon: true,
  },
  {
    id: 'web',
    image: downloadWeb,
    labelKey: 'downloadForWeb',
    comingSoon: true,
  }
];

const features = [
  { image: featureVoiceAi, titleKey: 'featureVoiceTitle', descKey: 'featureVoiceDesc' },
  { image: featureFocus, titleKey: 'featureFocusTitle', descKey: 'featureFocusDesc' },
  { image: featureMulti, titleKey: 'featureMultiTitle', descKey: 'featureMultiDesc' },
  { image: featurePrivacy, titleKey: 'featurePrivacyTitle', descKey: 'featurePrivacyDesc' },
  { image: featureNative, titleKey: 'featureNativeTitle', descKey: 'featureNativeDesc' },
  { image: featureSummaries, titleKey: 'featureSummariesTitle', descKey: 'featureSummariesDesc', comingSoon: true },
];
---

<BaseLayout title="Vasyapp - The Telegram Client for Deep Focus">
  <script is:inline define:vars={{ translations }}>
    window.translations = translations;
  </script>

  <div class="page">
    <header class="header glass">
      <div style="display: flex; align-items: center; gap: 10px;">
        <Image src={logoSvg} alt="Vasyapp Logo" width={32} height={32} loading="eager" fetchpriority="high" />
        <span class="logoTitle" data-t="appName">{t.appName}</span>
        <span class="versionBadge">{APP_VERSION}</span>
      </div>
      <nav style="display: flex; gap: 2rem; align-items: center;">
        <div class="langSwitcher">
          <button
            onclick="setLanguage('en')"
            class="langBtn"
            data-lang="en"
            aria-label="Switch language to English"
          >
            EN
          </button>
          <button
            onclick="setLanguage('ru')"
            class="langBtn"
            data-lang="ru"
            aria-label="Switch language to Russian"
          >
            RU
          </button>
        </div>
        <a href="#download" class="btn-primary" style="padding: 0.6rem 1.2rem;" data-t="download">{t.download}</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <h1 class="heroTitle">
            <span data-t="heroTitle">{t.heroTitle}</span>
            <span class="heroAccent" data-t="heroTitleAccent">{t.heroTitleAccent}</span>
          </h1>
          <p class="heroSubtitle" data-t="heroSubtitle">{t.heroSubtitle}</p>
          <div class="heroActions">
            <a href="#download" class="btn-primary" data-t="getStarted">{t.getStarted}</a>
            <a href="#features" class="btnSecondary" data-t="learnMore">{t.learnMore}</a>
          </div>

          <div class="mockupWrapper">
            <div class="appMockup">
              <aside class="sidebar">
                <div class="sidebarHeader">
                  <div class="accSwitcher">
                    <div class="circlesGroup">
                      <div class="accCircle accActive" style="--index: 0" data-t="accS">{t.accS}</div>
                      <div class="accCircle" style="--index: 1" data-t="accE">{t.accE}</div>
                      <div class="accCircle" style="--index: 2" data-t="accN">{t.accN}</div>
                      <div class="accCircle accAdd" style="--index: 3">+</div>
                    </div>
                  </div>
                  <div class="sidebarActions">
                    <div class="searchToggle" role="searchbox" aria-label="Search chats">
                      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                      <span class="searchText" data-t="searchPlaceholder">{t.searchPlaceholder}</span>
                    </div>
                    <button class="iconBtn" aria-label="Settings">
                      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 00-2 2v.18a2 2 0 01-1 1.73l-.43.25a2 2 0 01-2 0l-.15-.08a2 2 0 00-2.73.73l-.22.38a2 2 0 00.73 2.73l.15.1a2 2 0 011 1.72v.51a2 2 0 01-1 1.74l-.15.09a2 2 0 00-.73 2.73l.22.38a2 2 0 002.73.73l.15-.08a2 2 0 012 0l.43.25a2 2 0 011 1.73V20a2 2 0 002 2h.44a2 2 0 002-2v-.18a2 2 0 011-1.73l.43-.25a2 2 0 012 0l.15.08a2 2 0 002.73-.73l.22-.39a2 2 0 00-.73-2.73l-.15-.08a2 2 0 01-1-1.74v-.5a2 2 0 011-1.74l.15-.09a2 2 0 00.73-2.73l-.22-.38a2 2 0 00-2.73-.73l-.15.08a2 2 0 01-2 0l-.43-.25a2 2 0 01-1-1.73V4a2 2 0 00-2-2z" /><circle cx="12" cy="12" r="3" /></svg>
                    </button>
                  </div>
                </div>

                <div class="chatFilters">
                  <div class="filterBtn" data-t="filterContacts">{t.filterContacts}</div>
                  <div class="filterBtn filterActive" data-t="filterChats">{t.filterChats}</div>
                  <div class="filterBtn" data-t="filterFavorites">{t.filterFavorites}</div>
                </div>

                <div class="chatList">
                  <div class="chatItem">
                    <div class="chatAvatar">P</div>
                    <div class="chatInfo">
                      <div class="chatInfoTop">
                        <span class="chatTitle">Pavel Durov</span>
                        <span class="chatTime">12:04</span>
                      </div>
                      <div class="chatPreview">The feature looks great!</div>
                    </div>
                  </div>
                  <div class="chatItem">
                    <div class="chatAvatar">W</div>
                    <div class="chatInfo">
                      <div class="chatInfoTop">
                        <span class="chatTitle">Work Group</span>
                        <span class="chatTime">11:58</span>
                      </div>
                      <div class="chatPreview">Meeting in 5 mins</div>
                    </div>
                  </div>
                  <div class="chatItem chatSelected">
                    <div class="chatAvatar">A</div>
                    <div class="chatInfo">
                      <div class="chatInfoTop">
                        <span class="chatTitle" data-t="mockupChatName">{t.mockupChatName}</span>
                        <span class="chatTime">10:30</span>
                      </div>
                      <div class="chatInfoBottom">
                        <div class="chatPreview" data-t="mockupVoiceMsg">{t.mockupVoiceMsg}</div>
                        <div class="unreadCount">2</div>
                      </div>
                    </div>
                  </div>
                </div>
              </aside>

              <section class="chatArea">
                <div class="chatHeader">
                  <div class="chatHeaderLeft">
                    <div class="chatHeaderInfo">
                      <div class="chatHeaderTitle" data-t="mockupChatName">{t.mockupChatName}</div>
                      <div class="chatHeaderStatus" data-t="mockupStatus">{t.mockupStatus}</div>
                    </div>
                  </div>
                  <div class="chatHeaderActions">
                    <div class="iconBtn" aria-label="Search conversation"><svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg></div>
                    <div class="iconBtn" aria-label="More options"><svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="6" r="1" fill="currentColor" stroke="none" /><circle cx="12" cy="12" r="1" fill="currentColor" stroke="none" /><circle cx="12" cy="18" r="1" fill="currentColor" stroke="none" /></svg></div>
                  </div>
                </div>

                <div class="messageList">
                  <div class="messageListInner">
                    <div class="message incoming">
                      <div class="messageBubble">
                        <div class="messageText" data-t="mockupGreeting">{t.mockupGreeting}</div>
                        <div class="messageMeta">10:28</div>
                      </div>
                    </div>
                    <div class="message outgoing">
                      <div class="messageBubble">
                        <div class="messageText" data-t="mockupReply">{t.mockupReply}</div>
                        <div class="messageMeta">10:29 <span class="ticks">✓✓</span></div>
                      </div>
                    </div>
                    <div class="message incoming">
                      <div class="messageBubble">
                        <div class="voiceMessage">
                          <div class="voicePlayBtn">▶</div>
                          <div class="waveform">
                            {[12, 18, 14, 20, 16, 12, 18, 14, 10, 16, 14, 12, 16, 14, 10, 12].map((h) => (
                              <div class="waveformBar" style={`height: ${h}px`}></div>
                            ))}
                          </div>
                          <div class="voiceMetaInfo">0:12</div>
                        </div>
                        <div class="transcription" data-t="mockupVoiceTranscription">
                          "{t.mockupVoiceTranscription}"
                        </div>
                        <div class="messageMeta">10:30</div>
                      </div>
                    </div>
                    <div class="message outgoing">
                      <div class="messageBubble">
                        <div class="messageText" data-t="mockupFinalReply">{t.mockupFinalReply}</div>
                        <div class="messageMeta">10:31 <span class="ticks">✓✓</span></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="messageInputArea">
                  <div class="messageInputContainer">
                    <div class="messageInputInner">
                      <div class="messagePlaceholder" data-t="mockupInputPlaceholder">{t.mockupInputPlaceholder}</div>
                    </div>
                    <div class="inputAction" aria-label="Record voice message">
                      <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" /><path d="M19 10v2a7 7 0 0 1-14 0v-2" /><line x1="12" y1="19" x2="12" y2="22" /></svg>
                    </div>
                  </div>
                </div>
              </section>

              <div class="contentBg"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="features">
        <div class="container">
          <h2 class="sectionTitle" data-t="featuresTitle">{t.featuresTitle}</h2>
          <div class="featuresGrid">
            {features.map((f) => (
              <div class={`featureCard ${f.comingSoon ? 'featureFuture' : ''}`}>
                {f.comingSoon && <div class="badge" data-t="comingSoon">{t.comingSoon}</div>}
                <div class="featureImage">
                  <Image src={f.image} alt={t[f.titleKey as keyof typeof t]} />
                </div>
                <h3 data-t={f.titleKey}>{t[f.titleKey as keyof typeof t]}</h3>
                <p data-t={f.descKey}>{t[f.descKey as keyof typeof t]}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="download" class="downloadSection">
        <div class="container">
          <h2 class="downloadTitle">
            <span data-t="downloadTitle">{t.downloadTitle}</span>
            <span class="heroAccent" data-t="downloadTitleAccent">{t.downloadTitleAccent}</span>
          </h2>
          <p class="downloadSubtitle" data-t="downloadSubtitle">{t.downloadSubtitle}</p>

          <div class="downloadGrid">
            {downloads.map((dl) => (
              <div
                class={`downloadCard ${dl.comingSoon ? 'downloadCardComingSoon' : ''}`}
                data-platform={dl.id}
              >
                {dl.comingSoon && (
                  <div class="comingSoonBadge" data-t="comingSoon">{t.comingSoon}</div>
                )}
                <div class="downloadCardImage">
                  <Image src={dl.image} alt={t[dl.labelKey as keyof typeof t]} />
                </div>
                <h3 class="downloadCardTitle" data-t={dl.labelKey}>{t[dl.labelKey as keyof typeof t]}</h3>
                {!dl.comingSoon && dl.variants && (
                  <div class="downloadVariants">
                    {dl.variants.map((v) => (
                      <a href={v.href} class="downloadBtn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                        <span data-t={v.labelKey}>{t[v.labelKey as keyof typeof t]}</span>{v.ext}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>

          <a
            href="https://github.com/suenot/vasya/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="allReleasesLink"
            data-t="viewAllReleases"
          >
            {t.viewAllReleases} →
          </a>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="container">
        <Image src={logoSvg} alt="Vasyapp Logo" width={48} height={48} style="margin-bottom: 1rem;" />
        <p data-t="footerText">{t.footerText}</p>
        <div class="footerLinks">
          <a href="https://github.com/suenot/vasya" target="_blank" rel="noopener noreferrer" data-t="github">{t.github}</a>
          <a href="/privacy" data-t="privacy">{t.privacy}</a>
          <a href="/terms" data-t="terms">{t.terms}</a>
        </div>
        <div class="footerReforms">
          ⚡ <a href="https://reforms.ai" target="_blank" rel="noopener noreferrer">Built with Reforms.AI</a> • AI-powered projects for companies
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
