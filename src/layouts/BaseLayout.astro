---
import '../styles/globals.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "The Telegram Client for Deep Focus" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		
		<link 
			rel="preload" 
			as="style" 
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
		>
		<link 
			rel="stylesheet" 
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" 
			media="print" 
			onload="this.media='all'"
		>
		<noscript>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap">
		</noscript>
	</head>
	<body>
		<slot />
	</body>
</html>

	<script is:inline>
		// High-priority script to avoid flash of untranslated content and reflows
		(function() {
			const savedLang = localStorage.getItem('lang');
			const browserLang = navigator.language.split('-')[0];
			const lang = savedLang || (browserLang === 'ru' ? 'ru' : 'en');
			document.documentElement.setAttribute('lang', lang);
			
			// OS detection
			const ua = navigator.userAgent.toLowerCase();
			let os = null;
			if (/android/.test(ua)) os = 'android';
			else if (/mac/.test(ua)) os = 'mac';
			else if (/win/.test(ua)) os = 'windows';
			else if (/linux/.test(ua)) os = 'linux';
			if (os) document.documentElement.setAttribute('data-os', os);
		})();

		function updateContent(lang) {
			const elements = document.querySelectorAll('[data-t]');
			if (window.translations && window.translations[lang]) {
				const t = window.translations[lang];
				elements.forEach(el => {
					const key = el.getAttribute('data-t');
					if (t[key]) {
						if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
							el.placeholder = t[key];
						} else {
							el.textContent = t[key];
						}
					}
				});
			}
			
			document.querySelectorAll('.langBtn').forEach(btn => {
				btn.setAttribute('data-active', btn.getAttribute('data-lang') === lang);
			});

			localStorage.setItem('lang', lang);
		}

		window.setLanguage = (lang) => {
			document.documentElement.setAttribute('lang', lang);
			updateContent(lang);
		};

		document.addEventListener('DOMContentLoaded', () => {
			const lang = document.documentElement.getAttribute('lang');
			const os = document.documentElement.getAttribute('data-os');
			
			if (lang) updateContent(lang);
			
			if (os) {
				const card = document.querySelector(`[data-platform="${os}"]`);
				if (card) card.classList.add('recommended');
			}
		});
	</script>
