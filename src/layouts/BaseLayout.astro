---
import '@fontsource-variable/inter';
import '@fontsource-variable/outfit';
import { SEO } from "astro-seo";
import { Image } from 'astro:assets';
import globalTranslations from '../data/translations.json';
import logoSvg from '../assets/vasyapp.svg';
import { APP_VERSION } from '../constants';
import '../styles/globals.css';

interface Props {
	title: string;
	description?: string;
	showDownloadInNav?: boolean;
	translationsOverride?: any;
}

const { 
	title, 
	description = "The Telegram Client for Deep Focus", 
	showDownloadInNav = false,
	translationsOverride
} = Astro.props;

// Merge global translations with potential page overrides
const translations = {
    en: { ...globalTranslations.en, ...(translationsOverride?.en || {}) },
    ru: { ...globalTranslations.ru, ...(translationsOverride?.ru || {}) }
};

const t = translations.en;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og.png', Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" href="/vasyapp.png" />
		
		<SEO
			title={title}
			description={description}
			canonical={canonicalURL.toString()}
			openGraph={{
				basic: {
					title: title,
					type: "website",
					image: ogImageURL.toString(),
					url: canonicalURL.toString(),
				},
				image: {
					alt: "Vasyapp Logo",
				}
			}}
			twitter={{
				creator: "@suenot",
				card: "summary_large_image",
				site: "@suenot",
				title: title,
				description: description,
				image: ogImageURL.toString(),
			}}
			extend={{
				meta: [
					{ name: "viewport", content: "width=device-width" },
					{ name: "generator", content: Astro.generator },
					{ name: "apple-mobile-web-app-capable", content: "yes" },
					{ name: "apple-mobile-web-app-status-bar-style", content: "default" },
				],
			}}
		/>
		
		<!-- Critical styles to prevent white flash -->
		<style is:inline>
			:root { --bg-primary: #0f171e; }
			html, body { background-color: #0f171e; margin: 0; }
		</style>

		<script is:inline define:vars={{ translations }}>
			window.translations = translations;
		</script>

		<script is:inline>
			(function() {
				const savedLang = localStorage.getItem('lang');
				const browserLang = navigator.language.split('-')[0];
				const lang = savedLang || (browserLang === 'ru' ? 'ru' : 'en');
				document.documentElement.setAttribute('lang', lang);
				
				const ua = navigator.userAgent.toLowerCase();
				let os = 'web';
				if (/android/.test(ua)) os = 'android';
				else if (/mac/.test(ua)) os = 'mac';
				else if (/win/.test(ua)) os = 'windows';
				else if (/linux/.test(ua)) os = 'linux';
				document.documentElement.setAttribute('data-os', os);
			})();

			function updateContent(lang) {
				const translations = window.translations;
				if (!translations || !translations[lang]) return;
				
				const t = translations[lang];
				const elements = document.querySelectorAll('[data-t]');
				const langBtns = document.querySelectorAll('.langBtn');
				
				requestAnimationFrame(() => {
					for (let i = 0; i < elements.length; i++) {
						const el = elements[i];
						const key = el.getAttribute('data-t');
						const val = t[key];
						if (val) {
							if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
								el.placeholder = val;
							} else {
								el.textContent = val;
							}
						}
					}
					
					for (let i = 0; i < langBtns.length; i++) {
						const btn = langBtns[i];
						btn.setAttribute('data-active', btn.getAttribute('data-lang') === lang);
					}
				});

				localStorage.setItem('lang', lang);
			}

			window.setLanguage = (lang) => {
				if (document.documentElement.getAttribute('lang') === lang) return;
				document.documentElement.setAttribute('lang', lang);
				updateContent(lang);
			};

			document.addEventListener('DOMContentLoaded', () => {
				const lang = document.documentElement.getAttribute('lang');
				if (lang && lang !== 'en') {
					updateContent(lang);
				} else {
					document.querySelectorAll('.langBtn').forEach(btn => {
						btn.setAttribute('data-active', btn.getAttribute('data-lang') === 'en');
					});
				}
			});
		</script>
	</head>
	<body>
		<div class="page">
			<header class="header glass">
				<div style="display: flex; align-items: center; gap: 10px;">
					<a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit;">
						<Image src={logoSvg} alt="Vasyapp Logo" width={32} height={32} loading="eager" fetchpriority="high" />
						<span class="logoTitle" data-t="appName">{t.appName}</span>
					</a>
					<span class="versionBadge">{APP_VERSION}</span>
				</div>
				<nav style="display: flex; gap: 2rem; align-items: center;">
					<div class="langSwitcher">
						<button onclick="setLanguage('en')" class="langBtn" data-lang="en" aria-label="Switch language to English">EN</button>
						<button onclick="setLanguage('ru')" class="langBtn" data-lang="ru" aria-label="Switch language to Russian">RU</button>
					</div>
					{showDownloadInNav && (
						<a href="#download" class="btn-primary" style="padding: 0.6rem 1.2rem;" data-t="download">{t.download}</a>
					)}
				</nav>
			</header>

			<slot />

			<footer class="footer">
				<div class="container">
					<Image src={logoSvg} alt="Vasyapp Logo" width={48} height={48} style="margin-bottom: 1rem;" />
					<p data-t="footerText">{t.footerText}</p>
					<div class="footerLinks">
						<a href="https://github.com/suenot/vasya" target="_blank" rel="noopener noreferrer" data-t="github">{t.github}</a>
						<a href="/privacy" data-t="privacy">{t.privacy}</a>
						<a href="/terms" data-t="terms">{t.terms}</a>
					</div>
					<div class="footerReforms">
						⚡ <a href="https://reforms.ai" target="_blank" rel="noopener noreferrer">Built with Reforms.AI</a> • AI-powered projects for companies
					</div>
				</div>
			</footer>
		</div>
	</body>
</html>


