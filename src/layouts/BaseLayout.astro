import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';
import '../styles/globals.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "The Telegram Client for Deep Focus" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Critical styles to prevent white flash -->
		<style is:inline>
			:root { --bg-primary: #0f171e; }
			html, body { background-color: #0f171e; margin: 0; }
		</style>

		<script is:inline>
			// Optimized script to avoid forced reflows and redundant work
			(function() {
				const savedLang = localStorage.getItem('lang');
				const browserLang = navigator.language.split('-')[0];
				const lang = savedLang || (browserLang === 'ru' ? 'ru' : 'en');
				document.documentElement.setAttribute('lang', lang);
				
				const ua = navigator.userAgent.toLowerCase();
				let os = 'web';
				if (/android/.test(ua)) os = 'android';
				else if (/mac/.test(ua)) os = 'mac';
				else if (/win/.test(ua)) os = 'windows';
				else if (/linux/.test(ua)) os = 'linux';
				document.documentElement.setAttribute('data-os', os);
			})();

			function updateContent(lang) {
				if (!window.translations || !window.translations[lang]) return;
				
				const t = window.translations[lang];
				const elements = document.querySelectorAll('[data-t]');
				
				// Batch DOM updates in a single animation frame to prevent multiple reflows
				requestAnimationFrame(() => {
					elements.forEach(el => {
						const key = el.getAttribute('data-t');
						if (t[key]) {
							const value = t[key];
							if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
								if (el.placeholder !== value) el.placeholder = value;
							} else {
								// use textContent for better performance and to avoid reflow
								if (el.textContent !== value) el.textContent = value;
							}
						}
					});
					
					document.querySelectorAll('.langBtn').forEach(btn => {
						const isActive = btn.getAttribute('data-lang') === lang;
						btn.setAttribute('data-active', isActive);
					});
				});

				localStorage.setItem('lang', lang);
			}

			window.setLanguage = (lang) => {
				if (document.documentElement.getAttribute('lang') === lang) return;
				document.documentElement.setAttribute('lang', lang);
				updateContent(lang);
			};

			document.addEventListener('DOMContentLoaded', () => {
				const lang = document.documentElement.getAttribute('lang');
				// Only run translation if not in English (which is the static default)
				if (lang && lang !== 'en') {
					updateContent(lang);
				} else {
					// Even in English, we need to set active state for buttons
					document.querySelectorAll('.langBtn').forEach(btn => {
						btn.setAttribute('data-active', btn.getAttribute('data-lang') === 'en');
					});
				}
			});
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

